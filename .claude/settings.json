{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run test:run)",
      "Bash(npm test)",
      "Bash(npm run test:run -- :*)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(node scripts/validateCase.mjs)",
      "Bash(node scripts/validateCase.mjs :*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-preflight.sh\"",
            "timeout": 15,
            "statusMessage": "Loading project memory spine…"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-checks.sh\"",
            "timeout": 120,
            "statusMessage": "Checking edit (content validator / type-check)…"
          }
        ]
      }
    ]
  }
}
